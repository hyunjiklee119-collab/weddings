<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KIM CHUL SOO & LEE YOUNG HEE Wedding</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; -webkit-tap-highlight-color: transparent; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .tab-active { color: #fb7185; transform: scale(1.1); }
        .section { display: none; }
        .section.active { display: block; animation: fadeIn 0.6s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .modal { display: none; }
        .modal.active { display: flex; animation: fadeInShort 0.2s ease-out; }
        .modal-content { animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
        @keyframes fadeInShort { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="bg-stone-50 flex justify-center overflow-x-hidden">

    <div class="w-full max-w-[480px] bg-white shadow-2xl min-h-screen relative flex flex-col pb-20">
        
        <!-- 1. 메인 탭 (초대) -->
        <div id="section-main" class="section active">
            <!-- 대표 사진 영역 -->
            <div class="w-full h-96 bg-stone-100 rounded-b-3xl overflow-hidden relative shadow-lg flex items-center justify-center">
                <div class="text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-2 text-rose-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                    <p class="font-serif italic text-stone-400 text-lg">Our Special Day</p>
                </div>
                <div class="absolute bottom-6 left-0 right-0 text-center text-white drop-shadow-md">
                    <h2 class="text-2xl font-light tracking-widest mb-1 font-serif text-stone-800">KIM & LEE</h2>
                </div>
            </div>

            <!-- 초대 문구 -->
            <div class="py-12 px-8 text-center bg-white w-full">
                <p class="text-stone-500 text-sm mb-6 leading-relaxed">
                    함께 맞는 아침이 설레어<br />
                    서로의 곁을 지키기로 약속했습니다.<br /><br />
                    저희의 새로운 시작을<br />
                    함께 축복해주시면 감사하겠습니다.
                </p>
                
                <div class="border-t border-b border-stone-100 py-6 my-4">
                    <p class="text-lg font-medium text-stone-800 mb-2">2026년 5월 23일 토요일 낮 12시</p>
                    <p class="text-stone-600">더 라움 웨딩홀, 그랜드볼룸</p>
                </div>
            </div>

            <!-- 요약 정보 버튼 -->
            <div class="grid grid-cols-2 gap-4 px-6 w-full mb-10">
                <button onclick="openModal('gallery')" class="p-6 bg-stone-50 rounded-2xl flex flex-col items-center shadow-sm active:scale-95 transition-transform">
                    <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center mb-2 shadow-inner">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    </div>
                    <span class="text-xs text-stone-600 font-medium">상세 일정</span>
                </button>
                <button onclick="openModal('contact')" class="p-6 bg-stone-50 rounded-2xl flex flex-col items-center shadow-sm active:scale-95 transition-transform">
                    <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center mb-2 shadow-inner">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                    </div>
                    <span class="text-xs text-stone-600 font-medium">연락하기</span>
                </button>
            </div>
        </div>

        <!-- 2. 약도 탭 (오시는 길) -->
        <div id="section-map" class="section">
            <div class="p-8">
                <h3 class="text-xl font-serif text-stone-800 mb-6 text-center border-b pb-4 font-bold">오시는 길</h3>
                
                <div class="w-full aspect-square bg-stone-100 rounded-2xl mb-6 relative overflow-hidden flex items-center justify-center border border-stone-200 shadow-inner">
                    <p class="z-10 text-stone-400 font-medium bg-white/80 px-4 py-2 rounded-full text-xs">지도 서비스 연동 영역</p>
                </div>

                <div class="space-y-6">
                    <div>
                        <h4 class="flex items-center text-stone-800 font-semibold mb-2">
                            <div class="w-6 h-6 bg-blue-100 rounded-full flex items-center justify-center mr-2 text-blue-600 text-[10px]">P</div>
                            주차 안내
                        </h4>
                        <p class="text-sm text-stone-600 leading-relaxed ml-8">웨딩홀 내 지하 주차장 2시간 무료 이용 가능</p>
                    </div>
                    <div>
                        <h4 class="flex items-center text-stone-800 font-semibold mb-2">
                            <div class="w-6 h-6 bg-orange-100 rounded-full flex items-center justify-center mr-2 text-orange-600 text-[10px]">Sub</div>
                            지하철 안내
                        </h4>
                        <p class="text-sm text-stone-600 leading-relaxed ml-8">2호선 선릉역 7번 출구에서 도보 5분</p>
                    </div>
                    <div class="flex gap-2 pt-4">
                        <button class="flex-1 py-3 bg-stone-800 text-white rounded-xl text-sm font-medium shadow-md">카카오내비</button>
                        <button class="flex-1 py-3 bg-stone-100 text-stone-800 rounded-xl text-sm font-medium border border-stone-200">네이버 지도</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. 마음전할곳 탭 -->
        <div id="section-account" class="section">
            <div class="p-8">
                <h3 class="text-xl font-serif text-stone-800 mb-2 text-center font-bold">마음 전하실 곳</h3>
                <p class="text-xs text-stone-500 text-center mb-8">축복해주시는 마음 소중히 간직하겠습니다.</p>

                <!-- 신랑측 -->
                <div class="mb-8">
                    <div class="flex items-center mb-4">
                        <div class="h-[1px] flex-1 bg-stone-200"></div>
                        <span class="px-4 text-sm font-semibold text-stone-400">신랑 측</span>
                        <div class="h-[1px] flex-1 bg-stone-200"></div>
                    </div>
                    <div class="space-y-4">
                        <div class="bg-stone-50 p-5 rounded-2xl border border-stone-100 shadow-sm">
                            <p class="text-xs text-stone-400 mb-1">부) 김아빠</p>
                            <p class="text-stone-800 font-semibold">신한 110-123-456789</p>
                            <p class="text-stone-600 text-sm mt-1">김철수</p>
                            <div class="flex gap-2 mt-4">
                                <button onclick="copyAccount('110-123-456789')" class="flex-1 flex items-center justify-center gap-1 py-2 bg-white border border-stone-200 rounded-lg text-xs font-medium text-stone-600 hover:bg-stone-100">계좌 복사</button>
                                <button onclick="openModal('pay')" class="flex-1 py-2 bg-yellow-400 rounded-lg text-xs font-bold text-stone-800">페이 송금</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 신부측 -->
                <div>
                    <div class="flex items-center mb-4">
                        <div class="h-[1px] flex-1 bg-stone-200"></div>
                        <span class="px-4 text-sm font-semibold text-stone-400">신부 측</span>
                        <div class="h-[1px] flex-1 bg-stone-200"></div>
                    </div>
                    <div class="space-y-4">
                        <div class="bg-stone-50 p-5 rounded-2xl border border-stone-100 shadow-sm">
                            <p class="text-xs text-stone-400 mb-1">부) 이아빠</p>
                            <p class="text-stone-800 font-semibold">우리 1002-987-654321</p>
                            <p class="text-stone-600 text-sm mt-1">이영희</p>
                            <div class="flex gap-2 mt-4">
                                <button onclick="copyAccount('1002-987-654321')" class="flex-1 flex items-center justify-center gap-1 py-2 bg-white border border-stone-200 rounded-lg text-xs font-medium text-stone-600 hover:bg-stone-100">계좌 복사</button>
                                <button onclick="openModal('pay')" class="flex-1 py-2 bg-yellow-400 rounded-lg text-xs font-bold text-stone-800">페이 송금</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 하단 탭 바 -->
        <nav class="fixed bottom-0 w-full max-w-[480px] bg-white/80 backdrop-blur-md border-t border-stone-100 flex justify-around py-3 px-6 z-40">
            <button onclick="showSection('main')" id="tab-main" class="flex flex-col items-center transition-all tab-active">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                <span class="text-[10px] mt-1 font-medium">초대</span>
            </button>
            <button onclick="showSection('map')" id="tab-map" class="flex flex-col items-center transition-all text-stone-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span class="text-[10px] mt-1 font-medium">오시는길</span>
            </button>
            <button onclick="showSection('account')" id="tab-account" class="flex flex-col items-center transition-all text-stone-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                <span class="text-[10px] mt-1 font-medium">마음전하기</span>
            </button>
        </nav>
    </div>

    <!-- 모달 레이어 -->
    <div id="modal" class="modal fixed inset-0 z-50 items-end sm:items-center justify-center bg-black/40 backdrop-blur-[2px] p-0 sm:p-4">
        <div class="modal-content bg-white w-full max-w-[420px] rounded-t-3xl sm:rounded-3xl shadow-2xl overflow-hidden">
            <div class="flex justify-between items-center p-6 border-b border-stone-50">
                <h4 id="modal-title" class="font-semibold text-stone-800">알림</h4>
                <button onclick="closeModal()" class="p-1 hover:bg-stone-100 rounded-full text-stone-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div id="modal-body" class="p-6 max-h-[70vh] overflow-y-auto">
                <!-- 동적 내용 삽입 -->
            </div>
        </div>
    </div>

    <!-- 알림 토스트 -->
    <div id="toast" class="hidden fixed bottom-24 left-1/2 -translate-x-1/2 bg-stone-800/90 text-white text-xs px-6 py-3 rounded-full z-[60] shadow-xl">
        계좌번호가 복사되었습니다.
    </div>

    <script>
        // 탭 전환 로직
        function showSection(id) {
            // 모든 섹션 비활성화
            document.querySelectorAll('.section').forEach(sec => sec.classList.remove('active'));
            // 모든 탭 아이콘 비활성화
            document.querySelectorAll('nav button').forEach(btn => btn.classList.replace('text-rose-400', 'text-stone-400'));
            document.querySelectorAll('nav button').forEach(btn => btn.classList.remove('tab-active'));
            
            // 타겟 섹션 활성화
            document.getElementById('section-' + id).classList.add('active');
            document.getElementById('tab-' + id).classList.add('tab-active');
            document.getElementById('tab-' + id).classList.replace('text-stone-400', 'text-rose-400');
            
            // 스크롤 맨 위로
            window.scrollTo(0, 0);
        }

        // 모달 제어
        function openModal(type) {
            const modal = document.getElementById('modal');
            const title = document.getElementById('modal-title');
            const body = document.getElementById('modal-body');
            
            let content = '';
            if (type === 'gallery') {
                title.innerText = '상세 일정';
                content = `
                    <div class="space-y-4">
                        <div class="flex gap-4 p-4 bg-rose-50 rounded-xl">
                            <span class="text-rose-400 font-serif text-lg">11:30</span>
                            <span class="text-stone-600">신부 대기실 오픈 및 식전 영상</span>
                        </div>
                        <div class="flex gap-4 p-4 bg-stone-50 rounded-xl border border-stone-100 font-bold">
                            <span class="text-stone-800 font-serif text-lg">12:00</span>
                            <span class="text-stone-800">본식 시작 (그랜드볼룸)</span>
                        </div>
                    </div>
                `;
            } else if (type === 'contact') {
                title.innerText = '연락처 안내';
                content = `
                    <div class="space-y-4 text-sm">
                        <div class="flex justify-between items-center p-3 border-b">
                            <span>신랑 김철수</span>
                            <a href="tel:01000000000" class="text-blue-500 font-medium">전화하기</a>
                        </div>
                        <div class="flex justify-between items-center p-3 border-b">
                            <span>신부 이영희</span>
                            <a href="tel:01000000000" class="text-blue-500 font-medium">전화하기</a>
                        </div>
                    </div>
                `;
            } else if (type === 'pay') {
                title.innerText = '페이 송금 연동';
                content = `
                    <div class="grid grid-cols-1 gap-3">
                        <p class="text-xs text-stone-500 text-center mb-2">간편하게 송금 서비스를 이용하세요.</p>
                        <button class="flex items-center justify-between p-4 bg-[#FEE500] rounded-xl font-bold">카카오페이 송금 <span class="opacity-50">→</span></button>
                        <button class="flex items-center justify-between p-4 bg-[#0064FF] text-white rounded-xl font-bold">토스 송금하기 <span class="opacity-50">→</span></button>
                        <button class="flex items-center justify-between p-4 bg-[#03C75A] text-white rounded-xl font-bold">네이버페이 송금 <span class="opacity-50">→</span></button>
                    </div>
                `;
            }
            
            body.innerHTML = content;
            modal.classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }

        // 계좌 복사 기능
        function copyAccount(text) {
            const tempElem = document.createElement('textarea');
            tempElem.value = text;
            document.body.appendChild(tempElem);
            tempElem.select();
            document.execCommand('copy');
            document.body.removeChild(tempElem);
            
            const toast = document.getElementById('toast');
            toast.classList.remove('hidden');
            setTimeout(() => toast.classList.add('hidden'), 2000);
        }

        // 모달 외부 클릭 시 닫기
        window.onclick = function(event) {
            const modal = document.getElementById('modal');
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>
